{
  "name": "devor-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clear": "rm -rf .next && next dev -p 3000",
    "export:categories": "node scripts/export-services-tree.mjs",
    "build": "npm run export:categories && next build",
    "build:static": "NEXT_STATIC_EXPORT=1 NEXT_PUBLIC_BASE_PATH=/devor npm run export:categories && NEXT_STATIC_EXPORT=1 NEXT_PUBLIC_BASE_PATH=/devor next build",
    "start": "next start -p 3000"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
