# PostgreSQL
POSTGRES_DB=devor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/devor
JWT_SECRET=change_me_for_prod
STORAGE_MODE=local
MEDIA_ROOT=media
MEDIA_URL_PREFIX=/media
SMS_PROVIDER=mock
SHOW_DEBUG_OTP=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000

# Telegram (optional, for --profile telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=DevorLocalBot
